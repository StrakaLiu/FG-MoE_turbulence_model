forceCoeffs
{
    // Mandatory entries
    type            forceCoeffs;
    libs            (forces);
    patches         (wall); 

    // Field names
    p               p;
    U               U;
    rho             rhoInf;         // Indicates incompressible
    rhoInf          2.1267;
    magUInf         52.0783;

    liftDir         (-0.2680 0 1);
    dragDir         (1 0 0.2680);
    CofR            (0.25 0 0);     // Centre of rotation for moment calculations
    pitchAxis       (0 1 0);

    // Reference pressure
    pRef            0;
    lRef            1.0;            // Reference length: Chord length
    Aref            1.0;            // Reference area

}


