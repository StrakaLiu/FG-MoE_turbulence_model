FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "system";
    object      fvSchemes;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

ddtSchemes
{
    default         steadyState;
    //default         Euler;
}

gradSchemes
{
    // defult
    default         Gauss linear;

    // default cellLimited Gauss linear 0.5;
    // grad(U) faceLimited Gauss linear 1.0;
}

divSchemes
{
    default         none;

    div(U)          Gauss linear;
    div(phi,U)      Gauss upwind;
    //div(phi,U)      bounded Gauss limitedLinearV 1;
    //div(phi,U)      bounded Gauss linearUpwind grad(U);


    turbulence      Gauss upwind; 
    energy          Gauss upwind; 

    //turbulence      bounded Gauss linearUpwind grad(U);
    //energy          bounded Gauss upwind;

    div(phi,k)      $turbulence;
    div(phi,omega)  $turbulence;

    div(phi,e)      $energy;
    div(phi,K)      $energy;
    div(phi,Ekp)    $energy;



    div(phid,p)     Gauss upwind;
    div(phiv,p)     Gauss upwind;

    div((nuEff*dev2(T(grad(U))))) Gauss linear;
    div(((rho*nuEff)*dev2(T(grad(U)))))  Gauss linear;
    div((rho*nonlinearStress))  Gauss linear;
    div(nonlinearStress)  Gauss linear;
}

laplacianSchemes
{
    // very good quality mesh with uniform cell size
    // default Gauss linear orthogonal;

    // default         Gauss linear limited 1;

    default         Gauss linear corrected;
    laplacian(DomegaEff,omega) Gauss linear corrected;
}

interpolationSchemes
{
    default         linear;
}

snGradSchemes
{
    // default         limited 1;

    default         corrected;
}

wallDist
{
    method meshWave;
    correctWalls    true;
}


