FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      fvSolution;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

solvers
{
    p
    {
        solver                  PCG;
        preconditioner          DIC;
        tolerance               1e-6;
        relTol                  0.01;
    }

    pFinal
    {
       $p;
       relTol               0.;
    }

    "(h|U|k|omega|e)"
    {
        solver              PBiCGStab;
        preconditioner      DILU;
        tolerance           1e-8;
        relTol              0.0;
    }

    "(h|U|k|omega|e)Final"
    {
        $U;
        relTol              0.;
    }
}

PIMPLE
{
    nOuterCorrectors 1;
    nCorrectors     2;
    nNonOrthogonalCorrectors 1;
    pRefCell        10;
    pRefValue       0;
}

SIMPLE
{
    nNonOrthogonalCorrectors 1;
    pRefCell    0;
    pRefValue       0;
    consistent          yes;
}

relaxationFactors
{
    equations
    {
        U               0.7;
        "(k|epsilon|omega|nuTilda|phit|f)" 0.7;
        p               0.3;
    }
}

