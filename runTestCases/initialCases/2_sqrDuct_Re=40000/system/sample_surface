Description
    Writes graph data for specified fields along a surface, specified by one point and a normal direction.

\*---------------------------------------------------------------------------*/

type            surfaces;
libs            (sampling);

interpolationScheme	cellPoint;

surfaceFormat   raw;

fields  (U turbulenceProperties:R nonlinearR);

surfaces
(
yzPlane
{
	type        plane;
	point		(0.075 0 0);
	normal	(1 0 0);
	interpolate  true;
}
) ;

