FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "system";
    object      decomposeParDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

numberOfSubdomains  2;

//method              simple;

method              scotch;


simpleCoeffs
{
    n               ( 2 2 2 );
    delta           0.00001;
}

hierarchicalCoeffs
{
    n               ( 4 4 4 );
    delta           0.00001;
    order           xyz;
}

metisCoeffs
{
}

manualCoeffs
{
    dataFile        "";
}

distributed     no;

roots           ( );


