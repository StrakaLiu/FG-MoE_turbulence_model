FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      controlDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

libs
( 
  "lib_FG_MoE_incompressibleRAS.so"
) ;



startFrom       		latestTime;
//startFrom       		startTime;

startTime       		0;

stopAt          		nextWrite;

endTime         		5000;

deltaT          		1.0e-4; //1;

writeControl    		runTime;

writeInterval   		1.0;//100;

purgeWrite      		0;

writeFormat     		ascii;
//writeFormat     		binary;

writePrecision   		6;

writeCompression 		off;

timeFormat      		general;

timePrecision   		8;

adjustTimeStep			no;

runTimeModifiable 		true;

maxCo 					0.6;


functions
{

	turbulenceFields1
	{
		// Mandatory entries (unmodifiable)
		type            turbulenceFields;
		libs            (fieldFunctionObjects);
		fields           (R);
		enabled         true;
		executeControl  timeStep;
		executeInterval 1;
		writeControl    writeTime;
	}

	yPlus
	{
		// Mandatory entries (unmodifiable)
		type            yPlus;
		libs            (fieldFunctionObjects);
		enabled         true;
		executeControl  timeStep;
		executeInterval 10;
		writeControl    writeTime;
	}



   Average
   {
		type            fieldAverage;
		libs 			( "libfieldFunctionObjects.so" );
		enabled         false;
		timeStart	500;
		writeControl    writeTime ;
       fields
       (
       	  U
          {
              mean        	on;
              prime2Mean 	on;
              base        	time;
          }
		  p
          {
              mean        	on;
              prime2Mean 	on;
              base        	time;
          }
		  fd
          {
              mean        	on;
              prime2Mean 	off;
              base        	time;
          }
		  CDES
		  {
              mean        	on;
              prime2Mean 	off;
              base        	time;
          }
		  k
		  {
			  mean        	on;
              prime2Mean 	off;
              base        	time;		  
		  }
		  omega
		  {
			  mean        	on;
              prime2Mean 	off;
              base        	time;		  
		  }
		  turbulenceProperties:R
		  {
			  mean        	on;
              prime2Mean 	off;
              base        	time;		  
		  }
		  nonlinearR
		  {
			  mean        	on;
              			prime2Mean 	off;
              			base        	time;		  
		  }
      nut
      {
        mean          on;
                    prime2Mean  off;
                    base          time;     
      }
      C_mu_eff
      {
        mean          on;
        prime2Mean  off;
        base          time;     
      }
       );
   }

